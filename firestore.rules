rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net - ADMIN OVERRIDE
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.token != null && 'email' in request.auth.token && (
          request.auth.token.email.lower() == "admin@mafk.com" ||
          request.auth.token.email.lower() == "kareemsame77esoyam@gmail.com" ||
          request.auth.token.email.lower() == "mahraganalkeraza7esoyam@gmail.com"
        )
      );
    }

    // Specific Path Hardening for critical settings
    match /settings/exam_config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // In this system, church users are created with synthetic emails (e.g., church_abc@mafk.com)
      // which cannot be verified. Therefore, we just require the user to be signed in securely.
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token != null && 'email' in request.auth.token && (
          request.auth.token.email.lower() == "kareemsame77esoyam@gmail.com" ||
          request.auth.token.email.lower() == "mahraganalkeraza7esoyam@gmail.com" ||
          request.auth.token.email.lower() == "admin@mafk.com"
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isChurch(churchName) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'church' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.churchName == churchName;
    }

    function isValidUrl(url) {
      return url is string && url.size() < 1048576 && (url == '' || url.matches('^https?://.*') || url.matches('^data:image/.*'));
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.keys().size() <= 12 &&
             data.uid == userId &&
             data.email is string && data.email.size() < 256 &&
             data.role in ['admin', 'church'] &&
             (!('churchName' in data) || (data.churchName is string && data.churchName.size() < 200)) &&
             (!('isEnabled' in data) || (data.isEnabled is bool)) &&
             (!('password' in data) || (data.password is string)) &&
             (!('logoUrl' in data) || isValidUrl(data.logoUrl)) &&
             (!('country' in data) || (data.country is string && data.country.size() < 200)) &&
             (!('dashboardBg' in data) || (data.dashboardBg is string && data.dashboardBg.size() < 2000));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['churchName', 'details', 'grandTotal', 'timestamp']) &&
             data.keys().size() <= 15 &&
             data.churchName is string && data.churchName.size() < 200 &&
             data.details is list && data.details.size() <= 100 &&
             data.grandTotal is number &&
             data.timestamp is string &&
             (!('location' in data) || data.location is string) &&
             (!('year' in data) || data.year is string);
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['name', 'stage', 'churchName', 'competitions']) &&
             data.keys().size() <= 20 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.stage is string && data.stage.size() < 100 &&
             data.churchName is string && data.churchName.size() < 200 &&
             data.competitions is list && data.competitions.size() <= 10;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['churchName', 'message', 'timestamp']) &&
             data.keys().size() <= 5 &&
             data.churchName is string && data.churchName.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.timestamp is string &&
             (!('reply' in data) || (data.reply is string && data.reply.size() < 5000)) &&
             (!('year' in data) || data.year is string);
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'content', 'imageUrl', 'timestamp']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 10000 &&
             isValidUrl(data.imageUrl) &&
             data.timestamp is number &&
             (!('year' in data) || data.year is string);
    }

    function isValidExamLink(data) {
      return data.keys().hasAll(['stage', 'url']) &&
             data.keys().size() <= 6 &&
             data.stage is string && data.stage.size() < 100 &&
             isValidUrl(data.url) &&
             (!('year' in data) || data.year is string);
    }

    function isValidResult(data) {
      return data.keys().hasAll(['studentName', 'churchName', 'stage', 'score', 'grade', 'timestamp']) &&
             data.keys().size() <= 20 &&
             data.studentName is string && data.studentName.size() > 0 && data.studentName.size() < 200 &&
             data.churchName is string && data.churchName.size() < 200 &&
             data.stage is string && data.stage.size() < 100 &&
             data.score is number &&
             data.grade is string &&
             data.timestamp is string &&
             (!('year' in data) || data.year is string) &&
             (!('serial' in data) || data.serial is string) &&
             (!('academicScore' in data) || data.academicScore is number) &&
             (!('memorizationScore' in data) || data.memorizationScore is number) &&
             (!('q1Score' in data) || data.q1Score is number) &&
             (!('qScore' in data) || data.qScore is number);
    }

    function isValidSchedule(data) {
      return data.keys().hasAll(['examName', 'date', 'time', 'location']) &&
             data.keys().size() <= 6 &&
             data.examName is string && data.examName.size() < 500 &&
             data.date is string &&
             data.time is string &&
             data.location is string &&
             (!('year' in data) || data.year is string) &&
             (!('id' in data) || data.id is string);
    }

    function isValidExam(data) {
      return data.keys().hasAll(['stage', 'model', 'questions']) &&
             data.keys().size() <= 10 &&
             data.stage is string && data.stage.size() < 100 &&
             data.model is string && data.model.size() < 10 &&
             data.questions is list && data.questions.size() <= 100 &&
             (!('isActive' in data) || data.isActive is bool) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidExamLog(data) {
      return data.keys().hasAll(['studentId', 'timestamp']) &&
             data.keys().size() <= 15 &&
             data.studentId is string && data.timestamp is string &&
             (!('churchName' in data) || data.churchName is string) &&
             (!('userAgent' in data) || data.userAgent is string) &&
             (!('ip' in data) || data.ip is string) &&
             (!('studentName' in data) || data.studentName is string) &&
             (!('deviceId' in data) || data.deviceId is string) &&
             (!('deviceType' in data) || data.deviceType is string);
    }

    function isValidCarouselItem(data) {
      return data.keys().hasAll(['url', 'title']) &&
             data.keys().size() <= 4 &&
             isValidUrl(data.url) &&
             data.title is string && data.title.size() < 500 &&
             (!('order' in data) || data.order is number) &&
             (!('year' in data) || data.year is string);
    }

    function isValidCalculatorSetting(data) {
      return data.keys().hasAll(['stage', 'material', 'price', 'id', 'timestamp']) &&
             data.keys().size() <= 6 &&
             data.stage is string &&
             data.material is string &&
             data.price is number &&
             data.id is string &&
             data.timestamp is string &&
             (!('year' in data) || data.year is string);
    }

    function isValidActivityTeam(data) {
      return data.keys().hasAll(['churchName', 'activityType', 'members', 'maleCount', 'femaleCount', 'timestamp']) &&
             data.keys().size() <= 15 &&
             data.churchName is string &&
             data.activityType is string &&
             data.members is list &&
             data.maleCount is number &&
             data.femaleCount is number &&
             data.timestamp is string;
    }

    function isValidAppConfig(data) {
      return data.keys().size() <= 7 &&
             (!('activeYear' in data) || data.activeYear is string) &&
             (!('appLogo' in data) || isValidUrl(data.appLogo));
    }

    // ===============================================================
    // Rules Matching
    // ===============================================================

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Allow single lookups from the exam portal using the QR token ID
      allow get: if true; 
      // Strictly block global list queries to protect quotas and data leaks
      allow list: if request.auth != null && request.auth.token.role == 'superadmin';
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(incoming(), userId);
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming(), userId) && 
                    (isAdmin() || (incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['churchName', 'dashboardBg', 'logoUrl', 'country', 'password'])));
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && isChurch(resource.data.churchName));
      allow create: if isValidId(orderId) && 
                    isValidOrder(incoming()) && 
                    (isAdmin() || (isEmailVerified() && isChurch(incoming().churchName)));
      allow update: if isAdmin() && isValidOrder(incoming());
      allow delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow read, write: if true;
    }
    match /registrations_backup/{regId} {
      allow read, write: if true;
    }

    match /participants/{participantId} {
      allow read: if true;
      allow list: if true; // TEMPORARILY ALLOW LIST FOR MIGRATION
      allow create: if isValidId(participantId) && 
                    isValidParticipant(incoming()) && 
                    (isAdmin() || (isEmailVerified() && isChurch(incoming().churchName)));
      allow update: if (isAdmin() || (isEmailVerified() && isChurch(resource.data.churchName))) && 
                    isValidParticipant(incoming()) &&
                    (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['name', 'stage', 'gender', 'country', 'competitions', 'timestamp', 'serial', 'created_at', 'supabase_synced_id', 'year']));
      allow delete: if isAdmin() || (isSignedIn() && isChurch(resource.data.churchName));
    }

    match /inquiries/{inquiryId} {
      allow read: if isAdmin() || (isSignedIn() && isChurch(resource.data.churchName));
      allow create: if isValidId(inquiryId) && 
                    isValidInquiry(incoming()) && 
                    (isAdmin() || (isEmailVerified() && isChurch(incoming().churchName)));
      allow update: if isAdmin() && isValidInquiry(incoming()) && (incoming().diff(existing()).affectedKeys().hasOnly(['reply']) || incoming().diff(existing()).affectedKeys().hasOnly(['churchName']));
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidNews(incoming());
      allow delete: if isAdmin();
    }

    match /examLinks/{examLinkId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidExamLink(incoming());
      allow delete: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if true; // Public read for exam verification and results viewer
      allow create: if isAdmin() || (
        isValidId(resultId) && 
        isValidResult(incoming())
      );
      allow delete: if isAdmin() || (isSignedIn() && isChurch(resource.data.churchName));
      allow update: if isAdmin() || (
        isSignedIn() && isChurch(resource.data.churchName) &&
        isValidResult(incoming()) &&
        (
          incoming().diff(existing()).affectedKeys().hasAny(['academicScore', 'memorizationScore', 'copticL1Score', 'copticL2Score', 'data', 'submissionInfo', 'score', 'timestamp', 'isSubmitted'])
        )
      );

      match /previous_attempts/{attemptId} {
        allow read: if isAdmin();
        allow create: if isAdmin();
      }
    }

    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin() && isValidExam(incoming());
    }

    match /exam_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isValidExamLog(incoming());
    }

    match /active_sessions/{sessionId} {
      allow read: if true;
      allow create: if isValidId(sessionId);
      allow update: if true;
      allow delete: if true;
    }

    match /blacklist/{deviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSchedule(incoming());
      allow delete: if isAdmin();
    }

    match /activityTeams/{teamId} {
      allow read: if isAdmin() || (isSignedIn() && isChurch(resource.data.churchName));
      allow create: if isValidId(teamId) && 
                    isValidActivityTeam(incoming()) && 
                    (isAdmin() || (isEmailVerified() && isChurch(incoming().churchName)));
      allow update: if (isAdmin() || (isEmailVerified() && isChurch(resource.data.churchName))) && isValidActivityTeam(incoming());
      allow delete: if isAdmin();
    }

    match /calculator_settings/{settingId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCalculatorSetting(incoming());
      allow delete: if isAdmin();
    }

    match /churches/{churchId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /levels/{levelId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /activityStages/{stageId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /hymnStages/{stageId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /competitions/{compId} {
      allow read: if true;
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    match /public_churches/{churchId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(churchId);
      allow delete: if isAdmin();
    }

    match /carousel/{carouselId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidCarouselItem(incoming());
      allow delete: if isAdmin();
    }

    match /online_results/{resultId} {
      allow read: if isAdmin() || (isSignedIn() && isChurch(resource.data.churchName));
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && isChurch(resource.data.churchName));
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
